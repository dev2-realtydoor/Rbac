NODE_ENV=development
PORT=5000

# MongoDB
DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.mongodb.net/realtydoor?retryWrites=true&w=majority

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_ROUTE_ACCOUNT_ID=acc_xxxxxxxxxxxxxxxx

# WATI WhatsApp Business API
WATI_API_ENDPOINT=https://live-mt-server.wati.io/xxxxxxxx
WATI_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@realtydoor.com

# CORS
FRONTEND_URL=http://localhost:3000

# OTP Settings
OTP_EXPIRY_MINUTES=120
OTP_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=debug
